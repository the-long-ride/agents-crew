{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-crew.dev/schemas/crew-state.schema.json",
  "title": "CrewState",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "taskId": { "type": "string" },
    "workspaceRoot": { "type": "string" },
    "repositoryRoot": { "type": "string" },
    "baseCommit": { "type": "string" },
    "diffHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "changedFiles": { "type": "array", "items": { "type": "string" } },
    "reviewCycle": { "type": "integer", "minimum": 0 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "adapterConfig": { "type": "object", "additionalProperties": true }
  },
  "required": ["schemaVersion", "taskId"],
  "additionalProperties": false
}